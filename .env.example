# === PRODUCTION .env ===
SECRET_KEY=ganti-dengan-secret-key-yang-panjang-dan-acak
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database
USE_SQLITE=False
DB_NAME=seozaidly
DB_USER=seozaidly
DB_PASSWORD=ganti-dengan-password-kuat
DB_HOST=localhost
DB_PORT=5432

# AI Provider
# AI_PROVIDER memilih backend di balik AI Service layer.
# Saat ini hanya "openai_compatible" (SumoPod / OpenAI / gateway OpenAI-compatible).
# Untuk ganti provider, ubah nilai ini tanpa menyentuh kode aplikasi.
AI_PROVIDER=openai_compatible
AI_API_KEY=your-api-key
AI_BASE_URL=https://api.sumopod.com/v1
AI_DEFAULT_MODEL=gpt-4o-mini
AI_IMAGE_MODEL=

# (Opsional) Kosongkan jika tidak generate gambar
# AI_IMAGE_MODEL=dall-e-3

# Model strategy — fokus konsistensi, dengan fallback otomatis.
# AI_FALLBACK_MODELS: model cadangan (dipisah koma) jika model utama gagal/timeout.
# AI_TIMEOUT: batas waktu per panggilan (detik).
# AI_MAX_RETRIES: percobaan ulang tambahan per model sebelum pindah ke fallback.
AI_FALLBACK_MODELS=
AI_TIMEOUT=120
AI_MAX_RETRIES=1

# AI_ARTICLE_TEMPERATURE: temperatur generate/revisi artikel.
# Lebih rendah = lebih konsisten (tujuan utama model strategy). Default 0.6.
AI_ARTICLE_TEMPERATURE=0.6

# SERP Research Engine
# RESEARCH_PROVIDER memilih sumber data riset di balik abstraksi research.
# "llm" = sintesis via model AI (murah, jalan sekarang; competitor/heading estimasi,
# bukan SERP live). Provider SERP-API riil (DataForSEO/Serper) dicolok di sini nanti.
RESEARCH_PROVIDER=llm

# Keyword data (volume/difficulty/cpc). "null" = tidak ada data nyata, metric tetap None
# (TIDAK pernah dikarang). Ganti ke "dataforseo" saat provider nyata dipasang.
KEYWORD_DATA_PROVIDER=null

# Quality Gate
# QUALITY_MIN_SCORE: skor SEO minimum (0-100) agar artikel lolos & boleh auto-publish.
# QUALITY_MAX_REVISIONS: maksimum revisi otomatis bila skor belum lolos (guard biaya).
QUALITY_MIN_SCORE=70
QUALITY_MAX_REVISIONS=1

# Billing — payment provider seam (jangan hardcode).
# "mock" = simulasi gratis untuk dev/demo. "mayar" = live (set MAYAR_API_KEY).
PAYMENT_PROVIDER=mock
MAYAR_API_KEY=
MAYAR_CALLBACK_URL=

# Harga jual kredit (USD) untuk hitung margin di halaman billing.
CREDIT_PRICE_USD=0.30

# Threads OAuth (opsional). Kosong = mode demo connect (badge "DEMO" tegas di UI).
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_REDIRECT_URI=
